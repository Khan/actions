{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "rootDir": ".",
    "outDir": ".",
    "noEmit": false,
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "filter-files/index.ts",
    "check-for-changeset/index.ts",
    "get-changed-files/index.ts",
    "fix-workflows/index.ts",
    "../types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "**/dist/**"]
}
